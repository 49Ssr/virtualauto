* text=auto
*.md text eol=lf
*.json text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# The canonical master deliberately uses Markdown hard-break spaces and is
# checksum-locked, so whitespace checks must not rewrite or reject them.
research/automotive_materials/Automotive_Body_RnD_Master.md whitespace=-trailing-space

# Only original, reviewed regression scenes are eligible for LFS. Proprietary
# source and extracted assets remain forbidden regardless of transport.
workflows/blender/assets/**/*.blend filter=lfs diff=lfs merge=lfs -text
dev/tests/fixtures/blender/**/*.blend filter=lfs diff=lfs merge=lfs -text
