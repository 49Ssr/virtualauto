{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/schemas/experiment.schema.json",
  "title": "VirtualAuto experiment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "domain", "status", "hypothesis", "procedure", "acceptance_criteria"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^EXP-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "title": {"type": "string", "minLength": 3},
    "domain": {"type": "string", "minLength": 2},
    "status": {"enum": ["planned", "active", "blocked", "accepted", "rejected", "superseded"]},
    "hypothesis": {"type": "string", "minLength": 10},
    "source_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "blender_versions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "render_engines": {"type": "array", "items": {"enum": ["Cycles", "EEVEE", "Workbench", "not-applicable"]}, "uniqueItems": true},
    "procedure": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "failure_criteria": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "supersedes": {"type": ["string", "null"]}
  }
}
