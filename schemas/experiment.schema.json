{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/schemas/experiment.schema.json",
  "title": "VirtualAuto experiment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "domain",
    "status",
    "question",
    "hypothesis",
    "controlled_variables",
    "procedure",
    "acceptance_criteria",
    "failure_criteria",
    "required_evidence_types",
    "decision"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.1.0"},
    "id": {"type": "string", "pattern": "^EXP-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "title": {"type": "string", "minLength": 3},
    "domain": {"type": "string", "minLength": 2},
    "status": {"enum": ["planned", "active", "blocked", "accepted", "rejected", "superseded"]},
    "question": {"type": "string", "minLength": 10},
    "hypothesis": {"type": "string", "minLength": 10},
    "source_ids": {"type": "array", "items": {"type": "string", "minLength": 3}, "uniqueItems": true},
    "assumptions": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "blender_versions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "render_engines": {
      "type": "array",
      "items": {"enum": ["Cycles", "EEVEE", "Workbench", "not-applicable"]},
      "uniqueItems": true
    },
    "controlled_variables": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": ["string", "number", "integer", "boolean", "null"]}
    },
    "procedure": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "failure_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "required_evidence_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["image", "video", "exr", "blend", "mesh-report", "node-dump", "log", "measurement", "binary-layout", "other"]}
    },
    "result": {"type": ["string", "null"]},
    "decision": {"enum": ["pending", "accept", "reject", "revise", "supersede"]},
    "supersedes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
