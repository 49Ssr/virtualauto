{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/schemas/unknown-field.schema.json",
  "title": "VirtualAuto unknown field record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "source_asset_id", "container", "locator", "observed_representation", "preservation_status", "status"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^UNK-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "source_asset_id": {"type": "string", "pattern": "^AST-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "container": {"type": "string", "minLength": 2},
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resource_id": {"type": ["string", "null"]},
        "stream_index": {"type": ["integer", "null"], "minimum": 0},
        "byte_offset": {"type": ["integer", "null"], "minimum": 0},
        "byte_length": {"type": ["integer", "null"], "minimum": 1},
        "stride": {"type": ["integer", "null"], "minimum": 1}
      }
    },
    "observed_representation": {"type": "string", "minLength": 3},
    "raw_evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^EVD-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "confidence", "basis"],
        "properties": {
          "statement": {"type": "string", "minLength": 5},
          "confidence": {"enum": ["low", "medium", "high"]},
          "basis": {"type": "string", "minLength": 5},
          "discriminating_test": {"type": ["string", "null"]}
        }
      }
    },
    "preservation_status": {"enum": ["raw-preserved", "copied-to-intermediate", "not-yet-preserved", "lost"]},
    "status": {"enum": ["unknown", "partially-understood", "resolved", "superseded"]},
    "resolved_semantic": {"type": ["string", "null"]}
  }
}
