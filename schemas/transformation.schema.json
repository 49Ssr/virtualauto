{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/schemas/transformation.schema.json",
  "title": "VirtualAuto transformation record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "input_asset_ids", "output_asset_ids", "tool", "performed_at", "operator", "status", "loss_assessment"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^TRN-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "title": {"type": "string", "minLength": 3},
    "input_asset_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^AST-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "output_asset_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^AST-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version_or_commit"],
      "properties": {
        "external_tool_id": {"type": ["string", "null"], "pattern": "^EXT-[A-Z0-9]+(?:-[A-Z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "version_or_commit": {"type": "string", "minLength": 1}
      }
    },
    "command_or_operation": {"type": ["string", "null"]},
    "parameters": {"type": "object", "additionalProperties": true},
    "performed_at": {"type": "string", "format": "date-time"},
    "operator": {"type": "string", "minLength": 2},
    "status": {"enum": ["planned", "completed", "failed", "partial", "superseded"]},
    "loss_assessment": {"type": "string", "minLength": 5},
    "preserved_unknowns": {"type": "array", "items": {"type": "string", "pattern": "^UNK-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "log_evidence_id": {"type": ["string", "null"], "pattern": "^EVD-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}
  }
}
