{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/schemas/evidence.schema.json",
  "title": "VirtualAuto evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "experiment_id", "artifact_type", "provenance", "recorded_at"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^EVD-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "experiment_id": {"type": "string", "pattern": "^EXP-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "artifact_type": {"enum": ["image", "video", "exr", "blend", "mesh-report", "node-dump", "log", "measurement", "other"]},
    "repository_path": {"type": ["string", "null"]},
    "external_reference": {"type": ["string", "null"]},
    "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "provenance": {"type": "string", "minLength": 5},
    "recorded_at": {"type": "string", "format": "date-time"},
    "blender_version": {"type": ["string", "null"]},
    "render_engine": {"type": ["string", "null"]},
    "observation_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "rights_status": {"enum": ["original", "licensed", "reference-only", "unknown"]}
  },
  "anyOf": [
    {"required": ["repository_path"]},
    {"required": ["external_reference"]}
  ]
}
