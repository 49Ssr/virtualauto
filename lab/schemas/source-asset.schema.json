{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/lab/schemas/source-asset.schema.json",
  "title": "VirtualAuto source asset record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "source_kind", "format", "provenance", "rights_status", "custody_status", "recorded_at"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^AST-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "title": {"type": "string", "minLength": 3},
    "source_kind": {"enum": ["original", "game-package", "extracted-resource", "third-party-export", "scan", "photograph", "measurement", "document", "other"]},
    "format": {"type": "string", "minLength": 1},
    "provenance": {"type": "string", "minLength": 10},
    "rights_status": {"enum": ["original", "licensed", "lawfully-accessed-private", "reference-only", "unknown"]},
    "custody_status": {"enum": ["repository", "external-private-storage", "reference-only", "unavailable"]},
    "storage_reference": {"type": ["string", "null"]},
    "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "byte_size": {"type": ["integer", "null"], "minimum": 0},
    "recorded_at": {"type": "string", "format": "date-time"},
    "derived_from": {"type": "array", "items": {"type": "string", "pattern": "^AST-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "immutable": {"type": "boolean"},
    "notes": {"type": ["string", "null"]}
  }
}
