{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/lab/schemas/claim.schema.json",
  "title": "VirtualAuto claim record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "statement", "scope", "status", "confidence", "confidence_basis", "boundaries"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^CLM-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "statement": {"type": "string", "minLength": 10},
    "scope": {"type": "string", "minLength": 3},
    "status": {"enum": ["lead", "sourced", "hypothesis", "implemented", "validated", "rejected", "superseded"]},
    "source_ids": {"type": "array", "items": {"type": "string", "minLength": 3}, "uniqueItems": true},
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^EVD-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "experiment_ids": {"type": "array", "items": {"type": "string", "pattern": "^EXP-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "confidence": {"enum": ["low", "medium", "high"]},
    "confidence_basis": {"type": "string", "minLength": 5},
    "boundaries": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "contradictions": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "supersedes": {"type": "array", "items": {"type": "string", "pattern": "^CLM-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true}
  }
}
