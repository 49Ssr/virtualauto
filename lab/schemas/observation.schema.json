{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/49Ssr/virtualauto/lab/schemas/observation.schema.json",
  "title": "VirtualAuto observation record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "recorded_at",
    "observer",
    "raw_observation",
    "evidence_ids",
    "confidence",
    "confidence_basis",
    "status"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.1.0"},
    "id": {"type": "string", "pattern": "^OBS-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "experiment_id": {"type": ["string", "null"], "pattern": "^EXP-[A-Z0-9]+(?:-[A-Z0-9]+)+$"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "observer": {"type": "string", "minLength": 2},
    "asset_or_sample": {"type": ["string", "null"]},
    "part_or_region": {"type": ["string", "null"]},
    "raw_observation": {"type": "string", "minLength": 5},
    "measurement": {"type": ["object", "null"], "additionalProperties": true},
    "candidate_causes": {"type": "array", "items": {"type": "string", "minLength": 3}, "uniqueItems": true},
    "interpretation": {"type": ["string", "null"]},
    "discriminating_tests": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^EVD-[A-Z0-9]+(?:-[A-Z0-9]+)+$"}, "uniqueItems": true},
    "confidence": {"enum": ["low", "medium", "high"]},
    "confidence_basis": {"type": "string", "minLength": 5},
    "confounders": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "status": {"enum": ["observed", "reproduced", "contradicted", "superseded"]},
    "decision": {"enum": ["open", "promote-to-experiment", "accept-interpretation", "reject-interpretation", "supersede"]}
  }
}
