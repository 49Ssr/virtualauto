# Extracted or proprietary source data
/raw_assets/
/extracted/
/converted_assets/
/package_dumps/
/reference_capture/private/

# Game and package containers
*.pkg
*.dat
*.idx
*.ndx
*.rpk

# Large DCC, mesh, texture, and render artifacts
*.blend
*.blend1
*.fbx
*.obj
*.gltf
*.glb
*.dds
*.exr
*.hdr
*.mov
*.mp4

# Narrow exception for original, reviewed Git-LFS regression assets. Validation
# rejects raw Git blobs and any .blend outside these two directories.
!workflows/blender/assets/
!workflows/blender/assets/**/*.blend
!dev/tests/fixtures/blender/
!dev/tests/fixtures/blender/**/*.blend

# Local evidence caches and generated outputs
/lab/evidence/artifacts/
/build/
/dist/
/out/
/tmp/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
*.egg-info/

# IDE and operating-system metadata
.vs/
.idea/
.vscode/
.DS_Store
Thumbs.db

# Temporary and diagnostic files
*.tmp
*.log
*.bak
